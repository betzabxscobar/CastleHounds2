  botonContinuar: {fileID: 6797392797837180250}
  botonSalir: {fileID: 4065799585761001018}
  audioSource: {fileID: 4899489361737446281}
  sonidoSeleccion: {fileID: 8300000, guid: 85ac6e44a3bb8e349a875990658d13c8, type: 3}
  sonidoCorrecto: {fileID: 8300000, guid: 5daafa7acf2bb0f4f90ea40519407f3c, type: 3}
  sonidoIncorrecto: {fileID: 8300000, guid: fea127ef52236f944bc4ab97a1461f17, type: 3}
  preguntas:
  - acertijo: "Agua pasa por mi casa, cate que ya te lo dije. Que cosa ser\xE1?"
    respuestas:
    - Paraguas
    - "R\xEDo"
    - Aguacate
    - Casa
    respuestaCorrecta: 2
  - acertijo: "Tengo agujas, pero no pincho. Tengo n\xFAmeros, pero no cuento. \xBFQu\xE9
      soy?"
    respuestas:
    - Cactus
    - "Term\xF3metro"
    - Regla
    - Reloj
    respuestaCorrecta: 3
  - acertijo: "Tiene ciudades, pero no casas; tiene monta\xF1as, pero no \xE1rboles
      \xBFQu\xE9 es?"
    respuestas:
    - Mapa
    - Foto
    - Pueblo
    - Folleto
    respuestaCorrecta: 0
  - acertijo: "Me puedes romper sin tocarme. \xBFQu\xE9 soy?"
    respuestas:
    - Patricio
    - Promesa
    - Bruja
    - Papel
    respuestaCorrecta: 1
  - acertijo: "Soy tuyo, pero las dem\xE1s personas me usan m\xE1s que t\xFA. \xBFQu\xE9
      soy?"
    respuestas:
    - Tu Ex
    - Tu Nombre
    - Tu esfero
    - Tu dinero
    respuestaCorrecta: 1
